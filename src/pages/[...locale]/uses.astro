---
import Base from '../../layouts/Base.astro';
import { SITE_TITLE, WAKATIME_USERNAME } from '../../consts';
import { locales, type Locale, defaultLocale, useTranslations } from '../../i18n/ui';
import { useGroups, pick } from '../../data/uses';
import { getWakaStats } from '../../lib/wakatime';

export function getStaticPaths() {
	return locales.map((lang) => ({
		params: { locale: lang === defaultLocale ? undefined : lang },
		props: { lang },
	}));
}

const { lang } = Astro.props as { lang: Locale };
const t = useTranslations(lang);

const waka = await getWakaStats();

const icons: Record<string, string> = {
	desktop: 'M3 4h18v12H3zM8 20h8M12 16v4',
	code: 'm16 18 6-6-6-6M8 6l-6 6 6 6',
	terminal: 'm4 17 6-6-6-6M12 19h8',
	wrench: 'M14.7 6.3a4 4 0 0 1-5 5L3 18l3 3 6.7-6.7a4 4 0 0 1 5-5l-2.3-2.3 2.3-2.3-3-1-1 3Z',
	globe: 'M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20Zm0 0a15 15 0 0 1 0 20m0-20a15 15 0 0 0 0 20M2 12h20',
};
---

<Base title={`${t('uses.title')} — ${SITE_TITLE}`} description={t('uses.subtitle')} lang={lang}>
	<main class="mx-auto w-full max-w-3xl flex-1 px-4 py-16 sm:px-6">
		<header class="mb-10" data-reveal>
			<h1 class="text-4xl font-bold tracking-tight text-slate-900 dark:text-white">{t('uses.title')}</h1>
			<p class="mt-2 text-lg text-slate-600 dark:text-slate-400">{t('uses.subtitle')}</p>
		</header>

		{
			waka && (
				<section class="surface mb-10 p-6" data-reveal>
					<div class="flex items-center justify-between">
						<h2 class="text-sm font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">
							{t('wakatime.title')}
						</h2>
						<span class="text-xs text-slate-400">{t('wakatime.thisweek')}</span>
					</div>
					<p class="mt-2 text-2xl font-bold text-slate-900 dark:text-white">{waka.totalText}</p>
					<div class="mt-4 space-y-2">
						{waka.languages.map((l) => (
							<div>
								<div class="mb-1 flex justify-between text-xs text-slate-600 dark:text-slate-400">
									<span>{l.name}</span>
									<span>{l.text}</span>
								</div>
								<div class="h-1.5 overflow-hidden rounded-full bg-slate-200 dark:bg-slate-800">
									<div class="h-full rounded-full bg-brand-500" style={`width:${l.percent}%`} />
								</div>
							</div>
						))}
					</div>
					{WAKATIME_USERNAME && (
						<a
							href={`https://wakatime.com/@${WAKATIME_USERNAME}`}
							target="_blank"
							rel="noopener noreferrer"
							class="mt-4 inline-block text-sm text-brand-600 hover:underline dark:text-brand-400"
						>
							WakaTime →
						</a>
					)}
				</section>
			)
		}

		<div class="space-y-10">
			{
				useGroups.map((group) => (
					<section data-reveal>
						<h2 class="mb-4 flex items-center gap-2 text-xl font-semibold text-slate-900 dark:text-white">
							<span class="grid size-8 place-items-center rounded-lg bg-brand-500/10 text-brand-600 dark:text-brand-400">
								<svg class="size-4.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
									<path d={icons[group.icon]} />
								</svg>
							</span>
							{pick(group.title, lang)}
						</h2>
						<ul class="grid gap-3 sm:grid-cols-2">
							{group.items.map((item) => (
								<li class="surface card-hover p-4">
									<div class="flex items-baseline justify-between gap-2">
										<h3 class="font-semibold text-slate-900 dark:text-white">
											{item.url ? (
												<a href={item.url} target="_blank" rel="noopener noreferrer" class="hover:text-brand-600 dark:hover:text-brand-400">
													{item.name}
												</a>
											) : (
												item.name
											)}
										</h3>
									</div>
									<p class="mt-1 text-sm text-slate-600 dark:text-slate-400">{pick(item.desc, lang)}</p>
								</li>
							))}
						</ul>
					</section>
				))
			}
		</div>
	</main>
</Base>
