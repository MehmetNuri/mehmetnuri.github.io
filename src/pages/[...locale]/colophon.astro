---
import Base from '../../layouts/Base.astro';
import { SITE_TITLE, GITHUB_URL } from '../../consts';
import { locales, type Locale, defaultLocale, useTranslations } from '../../i18n/ui';

export function getStaticPaths() {
	return locales.map((lang) => ({
		params: { locale: lang === defaultLocale ? undefined : lang },
		props: { lang },
	}));
}

const { lang } = Astro.props as { lang: Locale };
const t = useTranslations(lang);
const en = lang === 'en';

const stack = [
	{ name: 'Astro', url: 'https://astro.build', role: { tr: 'İçerik odaklı statik site çatısı', en: 'Content-first static site framework' } },
	{ name: 'Tailwind CSS', url: 'https://tailwindcss.com', role: { tr: 'Utility-first stillendirme', en: 'Utility-first styling' } },
	{ name: 'TypeScript', url: 'https://www.typescriptlang.org', role: { tr: 'Tip güvenliği', en: 'Type safety' } },
	{ name: 'MDX', url: 'https://mdxjs.com', role: { tr: 'Markdown içinde bileşenler', en: 'Components inside Markdown' } },
	{ name: 'Expressive Code', url: 'https://expressive-code.com', role: { tr: 'Kod blokları (Twoslash dahil)', en: 'Code blocks (with Twoslash)' } },
	{ name: 'Pagefind', url: 'https://pagefind.app', role: { tr: 'İstemci tarafı tam metin arama', en: 'Client-side full-text search' } },
	{ name: 'Mermaid', url: 'https://mermaid.js.org', role: { tr: 'Metinden diyagram', en: 'Diagrams from text' } },
	{ name: 'GitHub Pages', url: 'https://pages.github.com', role: { tr: 'Yayınlama (GitHub Actions ile)', en: 'Hosting (via GitHub Actions)' } },
];

const decisions = en
	? [
			'Static-first: everything is rendered at build time, so the site is fast and cheap to host.',
			'Bilingual by design: every page exists in Turkish and English with proper hreflang.',
			'No heavy frameworks on the client — just a small vanilla script for interactions.',
			'Dark/light theme and a live accent-color picker, persisted in localStorage.',
			'Accessibility: skip links, focus styles, reduced-motion support and semantic markup.',
		]
	: [
			'Statik öncelikli: her şey build zamanında üretilir, böylece site hızlı ve ucuza barınır.',
			'Tasarımdan iki dilli: her sayfa Türkçe ve İngilizce, doğru hreflang ile var.',
			'İstemcide ağır çatı yok — etkileşimler için küçük bir vanilla script yeterli.',
			'Koyu/açık tema ve canlı vurgu rengi seçici, localStorage’da saklanır.',
			'Erişilebilirlik: atlama bağlantıları, odak stilleri, azaltılmış hareket desteği ve anlamlı işaretleme.',
		];
---

<Base title={`${t('colophon.title')} — ${SITE_TITLE}`} description={t('colophon.subtitle')} lang={lang}>
	<main class="mx-auto w-full max-w-2xl flex-1 px-4 py-16 sm:px-6">
		<header class="mb-10" data-reveal>
			<h1 class="text-4xl font-bold tracking-tight text-slate-900 dark:text-white">{t('colophon.title')}</h1>
			<p class="mt-2 text-lg text-slate-600 dark:text-slate-400">{t('colophon.subtitle')}</p>
		</header>

		<section class="mb-12" data-reveal>
			<h2 class="mb-4 text-sm font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">
				{en ? 'Built with' : 'Kullanılan teknolojiler'}
			</h2>
			<ul class="divide-y divide-slate-200 overflow-hidden rounded-xl border border-slate-200 dark:divide-slate-800 dark:border-slate-800">
				{
					stack.map((s) => (
						<li class="flex items-center justify-between gap-4 bg-white/40 px-4 py-3 dark:bg-slate-900/30">
							<a
								href={s.url}
								target="_blank"
								rel="noopener noreferrer"
								class="font-medium text-slate-900 hover:text-brand-600 dark:text-white dark:hover:text-brand-400"
							>
								{s.name}
							</a>
							<span class="text-right text-sm text-slate-500 dark:text-slate-400">{s.role[lang]}</span>
						</li>
					))
				}
			</ul>
		</section>

		<section class="mb-12" data-reveal>
			<h2 class="mb-4 text-sm font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">
				{en ? 'Decisions' : 'Kararlar'}
			</h2>
			<ul class="space-y-3">
				{
					decisions.map((d) => (
						<li class="flex gap-3 text-slate-700 dark:text-slate-300">
							<svg class="mt-1 size-4 shrink-0 text-brand-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<path d="M20 6 9 17l-5-5" />
							</svg>
							<span>{d}</span>
						</li>
					))
				}
			</ul>
		</section>

		<p class="text-sm text-slate-500 dark:text-slate-400" data-reveal>
			{en ? 'The full source is on ' : 'Tüm kaynak kod '}
			<a href={GITHUB_URL} target="_blank" rel="noopener noreferrer" class="text-brand-600 hover:underline dark:text-brand-400">GitHub</a>{en ? '.' : ' üzerinde.'}
		</p>
	</main>
</Base>
