---
import Base from '../../layouts/Base.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { getPostsByLocale, getTags, postSlug, slugify } from '../../lib/utils';
import { SITE_TITLE } from '../../consts';
import { locales, type Locale, defaultLocale, localizePath, useTranslations } from '../../i18n/ui';

export function getStaticPaths() {
	return locales.map((lang) => ({
		params: { locale: lang === defaultLocale ? undefined : lang },
		props: { lang },
	}));
}

const { lang } = Astro.props as { lang: Locale };
const t = useTranslations(lang);

const posts = await getPostsByLocale(lang);
const tags = getTags(posts);

// Yıllara göre grupla (yeni → eski).
const byYear = new Map<number, typeof posts>();
for (const p of posts) {
	const y = p.data.pubDate.getFullYear();
	if (!byYear.has(y)) byYear.set(y, []);
	byYear.get(y)!.push(p);
}
const years = [...byYear.keys()].sort((a, b) => b - a);

// Etiket bulutu için yazı sayısına göre boyutlandır.
const maxCount = Math.max(1, ...tags.map((t) => t.count));
const sizeFor = (c: number) => 0.8 + (c / maxCount) * 0.9; // rem
---

<Base title={`${t('archive.title')} — ${SITE_TITLE}`} description={t('archive.subtitle')} lang={lang}>
	<main class="mx-auto w-full max-w-3xl flex-1 px-4 py-16 sm:px-6">
		<header class="mb-10" data-reveal>
			<h1 class="text-4xl font-bold tracking-tight text-slate-900 dark:text-white">{t('archive.title')}</h1>
			<p class="mt-2 text-lg text-slate-600 dark:text-slate-400">
				{t('archive.subtitle')} · {posts.length} {t('archive.posts')}
			</p>
		</header>

		{
			tags.length > 0 && (
				<section class="surface mb-12 p-6" data-reveal>
					<h2 class="mb-4 text-sm font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">
						{t('archive.allTags')}
					</h2>
					<div class="flex flex-wrap items-baseline gap-x-4 gap-y-2">
						{tags.map((tag) => (
							<a
								href={localizePath(lang, `/etiket/${slugify(tag.name)}`)}
								class="text-slate-600 transition hover:text-brand-600 dark:text-slate-400 dark:hover:text-brand-400"
								style={`font-size:${sizeFor(tag.count)}rem`}
							>
								#{tag.name}
								<span class="align-super text-[0.6em] text-slate-400">{tag.count}</span>
							</a>
						))}
					</div>
				</section>
			)
		}

		{
			years.map((year) => (
				<section class="mb-10" data-reveal>
					<h2 class="mb-3 border-b border-slate-200 pb-2 text-2xl font-bold text-slate-900 dark:border-slate-800 dark:text-white">
						{year}
					</h2>
					<ul class="divide-y divide-slate-100 dark:divide-slate-800/60">
						{byYear.get(year)!.map((p) => (
							<li>
								<a
									href={localizePath(lang, `/blog/${postSlug(p)}`)}
									class="group flex items-baseline justify-between gap-4 py-3"
								>
									<span class="font-medium text-slate-800 transition group-hover:text-brand-600 dark:text-slate-200 dark:group-hover:text-brand-400">
										{p.data.title}
									</span>
									<time class="shrink-0 font-mono text-xs text-slate-400">
										<FormattedDate date={p.data.pubDate} lang={lang} />
									</time>
								</a>
							</li>
						))}
					</ul>
				</section>
			))
		}

		{posts.length === 0 && <p class="text-slate-500 dark:text-slate-400">{t('blog.empty')}</p>}
	</main>
</Base>
