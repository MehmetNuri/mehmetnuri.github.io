---
import { getCollection, render } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import FormattedDate from '../../../components/FormattedDate.astro';
import { noteSlug, getNoteTranslations } from '../../../lib/utils';
import { SITE_TITLE } from '../../../consts';
import { type Locale, defaultLocale, localizePath, useTranslations } from '../../../i18n/ui';

export async function getStaticPaths() {
	const notes = await getCollection('notes');
	return notes.map((note) => ({
		params: {
			locale: note.data.locale === defaultLocale ? undefined : note.data.locale,
			slug: noteSlug(note),
		},
		props: { note },
	}));
}

const { note } = Astro.props;
const lang = note.data.locale as Locale;
const t = useTranslations(lang);
const { Content } = await render(note);

const translations = await getNoteTranslations(note);
const langUrls = Object.fromEntries(
	Object.entries(translations).map(([l, slug]) => [l, localizePath(l as Locale, `/notes/${slug}`)]),
) as Partial<Record<Locale, string>>;
---

<Base
	title={`${note.data.title} — ${SITE_TITLE}`}
	description={note.data.description ?? note.data.title}
	lang={lang}
	langUrls={langUrls}
	ogImage={`/open-graph/${note.id}.png`}
>
	<main class="mx-auto w-full max-w-2xl flex-1 px-4 py-16 sm:px-6">
		<a
			href={localizePath(lang, '/notes')}
			class="text-sm text-slate-500 transition hover:text-brand-600 dark:text-slate-400 dark:hover:text-brand-400"
			>{t('notes.back')}</a
		>

		<article class="mt-6">
			<div class="flex items-center gap-2 text-xs text-slate-500 dark:text-slate-400">
				<FormattedDate date={note.data.pubDate} lang={lang} />
				{note.data.tags.length > 0 && (
					<span class="text-slate-400">· {note.data.tags.map((x) => `#${x}`).join(' ')}</span>
				)}
			</div>
			<h1 class="mt-2 text-3xl font-bold tracking-tight text-balance text-slate-900 dark:text-white">
				{note.data.title}
			</h1>

			<div class="prose prose-slate mt-6 max-w-none dark:prose-invert">
				<Content />
			</div>

			{
				note.data.source && (
					<p class="mt-8 border-t border-slate-200 pt-4 text-sm text-slate-500 dark:border-slate-800 dark:text-slate-400">
						{t('notes.source')}:{' '}
						<a
							href={note.data.source}
							target="_blank"
							rel="noopener noreferrer"
							class="text-brand-600 hover:underline dark:text-brand-400"
						>
							{note.data.source}
						</a>
					</p>
				)
			}
		</article>
	</main>
</Base>
