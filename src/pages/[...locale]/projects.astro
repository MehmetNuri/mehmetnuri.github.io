---
import Base from '../../layouts/Base.astro';
import { Badge } from '../../components/starwind/badge';
import { SITE_TITLE, GITHUB_URL, GITHUB_USERNAME } from '../../consts';
import { locales, type Locale, defaultLocale, useTranslations } from '../../i18n/ui';
import { featuredProjects } from '../../data/projects';
import { pick } from '../../data/uses';
import { getRepos } from '../../lib/github';

export function getStaticPaths() {
	return locales.map((lang) => ({
		params: { locale: lang === defaultLocale ? undefined : lang },
		props: { lang },
	}));
}

const { lang } = Astro.props as { lang: Locale };
const t = useTranslations(lang);

const repos = await getRepos(6);
// Öne çıkanlarda zaten gösterilen repoları otomatik listeden çıkar.
const featuredRepoNames = new Set(
	featuredProjects.map((p) => p.repo?.toLowerCase()).filter(Boolean) as string[],
);
const otherRepos = repos.filter(
	(r) => !featuredRepoNames.has(`${GITHUB_USERNAME}/${r.name}`.toLowerCase()),
);

const langColor: Record<string, string> = {
	TypeScript: '#3178c6',
	JavaScript: '#f1e05a',
	'C#': '#178600',
	Python: '#3572A5',
	Astro: '#ff5d01',
	HTML: '#e34c26',
	CSS: '#563d7c',
	Shell: '#89e051',
	Go: '#00ADD8',
	Rust: '#dea584',
};
---

<Base title={`${t('projects.title')} — ${SITE_TITLE}`} description={t('projects.subtitle')} lang={lang}>
	<main class="mx-auto w-full max-w-4xl flex-1 px-4 py-16 sm:px-6">
		<header class="mb-10" data-reveal>
			<h1 class="text-4xl font-bold tracking-tight text-slate-900 dark:text-white">{t('projects.title')}</h1>
			<p class="mt-2 text-lg text-slate-600 dark:text-slate-400">{t('projects.subtitle')}</p>
		</header>

		{
			featuredProjects.length > 0 && (
				<section class="mb-12" data-reveal>
					<h2 class="mb-4 text-sm font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">
						{t('projects.featured')}
					</h2>
					<div class="grid gap-4 sm:grid-cols-2">
						{featuredProjects.map((p) => (
							<a
								href={p.url}
								target="_blank"
								rel="noopener noreferrer"
								class="group surface card-hover flex flex-col p-5"
							>
								<h3 class="font-semibold text-slate-900 transition group-hover:text-brand-600 dark:text-white dark:group-hover:text-brand-400">
									{p.name}
								</h3>
								<p class="mt-1 flex-1 text-sm text-slate-600 dark:text-slate-400">{pick(p.desc, lang)}</p>
								<div class="mt-3 flex flex-wrap gap-1.5">
									{p.tags.map((tag) => (
										<Badge variant="secondary" size="sm">
											{tag}
										</Badge>
									))}
								</div>
							</a>
						))}
					</div>
				</section>
			)
		}

		{
			otherRepos.length > 0 && (
				<section data-reveal>
					<h2 class="mb-4 text-sm font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">
						{t('projects.fromGithub')}
					</h2>
					<div class="grid gap-3 sm:grid-cols-2">
						{otherRepos.map((r) => (
							<a
								href={r.url}
								target="_blank"
								rel="noopener noreferrer"
								class="group surface card-hover flex flex-col p-5"
							>
								<div class="flex items-center gap-2">
									<svg class="size-4 text-slate-400" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
										<path d="M2 2.5A2.5 2.5 0 0 1 4.5 0h8.75a.75.75 0 0 1 .75.75v12.5a.75.75 0 0 1-.75.75h-2.5a.75.75 0 0 1 0-1.5h1.75v-2h-8a1 1 0 0 0-.714 1.7.75.75 0 1 1-1.072 1.05A2.495 2.495 0 0 1 2 11.5Zm10.5-1h-8a1 1 0 0 0-1 1v6.708A2.486 2.486 0 0 1 4.5 9h8ZM5 12.25a.25.25 0 0 1 .25-.25h3.5a.25.25 0 0 1 .25.25v3.25a.25.25 0 0 1-.4.2l-1.45-1.087a.249.249 0 0 0-.3 0L5.4 15.7a.25.25 0 0 1-.4-.2Z" />
									</svg>
									<h3 class="truncate font-semibold text-slate-900 transition group-hover:text-brand-600 dark:text-white dark:group-hover:text-brand-400">
										{r.name}
									</h3>
								</div>
								{r.description && (
									<p class="mt-1.5 line-clamp-2 flex-1 text-sm text-slate-600 dark:text-slate-400">
										{r.description}
									</p>
								)}
								<div class="mt-3 flex items-center gap-4 text-xs text-slate-500 dark:text-slate-400">
									{r.language && (
										<span class="flex items-center gap-1.5">
											<span class="size-2.5 rounded-full" style={`background:${langColor[r.language] ?? '#94a3b8'}`} />
											{r.language}
										</span>
									)}
									<span class="flex items-center gap-1">
										<svg class="size-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
											<path d="m12 2 3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2Z" />
										</svg>
										{r.stars}
									</span>
								</div>
							</a>
						))}
					</div>
				</section>
			)
		}

		<div class="mt-10" data-reveal>
			<a
				href={GITHUB_URL}
				target="_blank"
				rel="noopener noreferrer"
				class="text-sm text-brand-600 hover:underline dark:text-brand-400"
			>
				{t('projects.viewAll')}
			</a>
		</div>
	</main>
</Base>
