---
import Base from '../layouts/Base.astro';
import { Button } from '../components/starwind/button';
import { SITE_TITLE } from '../consts';
---

<Base title={`404 — ${SITE_TITLE}`} description="Sayfa bulunamadı" lang="tr">
	<main
		class="mx-auto flex w-full max-w-2xl flex-1 flex-col items-center justify-center px-4 py-24 text-center sm:px-6"
	>
		<p
			class="bg-gradient-to-r from-brand-500 via-violet-500 to-cyan-400 bg-clip-text text-7xl font-extrabold tracking-tight text-transparent sm:text-8xl"
		>
			404
		</p>
		<h1 class="mt-4 text-2xl font-bold text-slate-900 dark:text-white">Sayfa bulunamadı</h1>
		<p class="mt-3 max-w-md text-slate-600 dark:text-slate-400">
			Aradığın sayfa taşınmış ya da hiç var olmamış olabilir. Üstteki aramayı (⌘K) kullanabilir
			veya aşağıdan devam edebilirsin.
		</p>
		<div class="mt-8 flex flex-wrap justify-center gap-3">
			<Button href="/" variant="primary">Anasayfa</Button>
			<Button href="/blog" variant="outline">Blog</Button>
		</div>
	</main>
</Base>
