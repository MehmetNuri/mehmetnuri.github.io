---
// Webmention.io etkileşimlerini gösterir. WEBMENTION.domain boşsa hiçbir şey
// render etmez (özellik kapalı). Veriler build zamanında çekilir.
import { webmentionsEnabled, type WebmentionSummary } from '../lib/webmentions';
import { type Locale, useTranslations } from '../i18n/ui';

interface Props {
	lang: Locale;
	data: WebmentionSummary;
	pageUrl: string;
}
const { lang, data } = Astro.props;
const t = useTranslations(lang);
const enabled = webmentionsEnabled();
const faces = [...data.likes, ...data.reposts];
---

{
	enabled && (
		<section class="mt-12 border-t border-slate-200 pt-8 dark:border-slate-800">
			<h2 class="mb-4 text-lg font-semibold text-slate-900 dark:text-white">{t('wm.title')}</h2>

			{data.total === 0 ? (
				<p class="text-sm text-slate-500 dark:text-slate-400">{t('wm.none')}</p>
			) : (
				<>
					{(data.likes.length > 0 || data.reposts.length > 0) && (
						<div class="mb-6 flex items-center gap-3">
							<div class="flex -space-x-2">
								{faces.slice(0, 12).map((wm) => (
									<a href={wm.author.url} target="_blank" rel="noopener noreferrer" title={wm.author.name}>
										{wm.author.photo ? (
											<img
												src={wm.author.photo}
												alt={wm.author.name}
												width="32"
												height="32"
												loading="lazy"
												class="size-8 rounded-full border-2 border-white object-cover dark:border-slate-900"
											/>
										) : (
											<span class="grid size-8 place-items-center rounded-full border-2 border-white bg-brand-500/20 text-xs font-semibold text-brand-700 dark:border-slate-900 dark:text-brand-300">
												{wm.author.name.charAt(0)}
											</span>
										)}
									</a>
								))}
							</div>
							<span class="text-sm text-slate-500 dark:text-slate-400">
								{data.likes.length} {t('wm.likes')} · {data.reposts.length} {t('wm.reposts')}
							</span>
						</div>
					)}

					{data.replies.length > 0 && (
						<div>
							<h3 class="mb-3 text-sm font-semibold text-slate-700 dark:text-slate-300">{t('wm.replies')}</h3>
							<ul class="space-y-4">
								{data.replies.map((wm) => (
									<li class="flex gap-3">
										{wm.author.photo ? (
											<img
												src={wm.author.photo}
												alt={wm.author.name}
												width="36"
												height="36"
												loading="lazy"
												class="size-9 shrink-0 rounded-full object-cover"
											/>
										) : (
											<span class="grid size-9 shrink-0 place-items-center rounded-full bg-brand-500/20 text-sm font-semibold text-brand-700 dark:text-brand-300">
												{wm.author.name.charAt(0)}
											</span>
										)}
										<div class="min-w-0">
											<a
												href={wm.url}
												target="_blank"
												rel="noopener noreferrer"
												class="text-sm font-medium text-slate-900 hover:text-brand-600 dark:text-white dark:hover:text-brand-400"
											>
												{wm.author.name}
											</a>
											{wm.content && (
												<p class="mt-0.5 text-sm text-slate-600 dark:text-slate-400">{wm.content}</p>
											)}
										</div>
									</li>
								))}
							</ul>
						</div>
					)}
				</>
			)}
		</section>
	)
}
