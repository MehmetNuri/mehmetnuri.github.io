---
// GitHub depo kartı (MDX içinde) — veriler BUILD ZAMANINDA çekilir:
//   <GitHubCard repo="withastro/astro" />
import { getRepo } from '../lib/github';
interface Props {
	repo: string; // "owner/name"
}
const { repo } = Astro.props;
const data = await getRepo(repo);
const url = data?.url ?? `https://github.com/${repo}`;
---

<a
	href={url}
	target="_blank"
	rel="noopener noreferrer"
	class="not-prose group my-6 flex flex-col gap-2 rounded-xl border border-slate-200 bg-white/40 p-5 transition hover:border-brand-500/40 hover:shadow-lg hover:shadow-brand-500/5 dark:border-slate-800 dark:bg-slate-900/30"
>
	<div class="flex items-center gap-2">
		<svg class="size-5 shrink-0 text-slate-500 dark:text-slate-400" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
			<path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"></path>
		</svg>
		<span class="font-semibold text-slate-900 transition group-hover:text-brand-600 dark:text-white dark:group-hover:text-brand-400">
			{repo}
		</span>
	</div>
	{data?.description && <p class="text-sm text-slate-600 dark:text-slate-400">{data.description}</p>}
	{
		data && (
			<div class="flex items-center gap-4 text-xs text-slate-500 dark:text-slate-400">
				{data.language && (
					<span>{data.language}</span>
				)}
				<span class="flex items-center gap-1">
					<svg class="size-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
						<path d="m12 2 3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2Z" />
					</svg>
					{data.stars}
				</span>
				<span class="flex items-center gap-1">
					<svg class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
						<circle cx="6" cy="6" r="2.5" /><circle cx="6" cy="18" r="2.5" /><circle cx="18" cy="8" r="2.5" />
						<path d="M6 8.5v7M18 10.5c0 4-6 2-6 5" />
					</svg>
					{data.forks}
				</span>
			</div>
		)
	}
</a>
