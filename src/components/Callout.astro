---
// Callout / admonition kutuları (MDX içinde):
//   <Callout type="tip" title="İpucu">İçerik...</Callout>
type CalloutType = 'note' | 'tip' | 'important' | 'warning' | 'caution';

interface Props {
	type?: CalloutType;
	title?: string;
}

const { type = 'note', title } = Astro.props;

const config: Record<CalloutType, { wrap: string; icon: string; label: string; path: string }> = {
	note: {
		wrap: 'border-blue-500/40 bg-blue-50 dark:bg-blue-500/10',
		icon: 'text-blue-600 dark:text-blue-400',
		label: 'Not',
		path: 'M12 16v-4M12 8h.01M22 12a10 10 0 1 1-20 0 10 10 0 0 1 20 0Z',
	},
	tip: {
		wrap: 'border-emerald-500/40 bg-emerald-50 dark:bg-emerald-500/10',
		icon: 'text-emerald-600 dark:text-emerald-400',
		label: 'İpucu',
		path: 'M9 18h6M10 22h4M12 2a7 7 0 0 0-4 12.7c.6.5 1 1.3 1 2.1h6c0-.8.4-1.6 1-2.1A7 7 0 0 0 12 2Z',
	},
	important: {
		wrap: 'border-violet-500/40 bg-violet-50 dark:bg-violet-500/10',
		icon: 'text-violet-600 dark:text-violet-400',
		label: 'Önemli',
		path: 'M12 8v4m0 4h.01M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z',
	},
	warning: {
		wrap: 'border-amber-500/40 bg-amber-50 dark:bg-amber-500/10',
		icon: 'text-amber-600 dark:text-amber-400',
		label: 'Uyarı',
		path: 'M10.3 3.9 1.8 18a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0ZM12 9v4m0 4h.01',
	},
	caution: {
		wrap: 'border-red-500/40 bg-red-50 dark:bg-red-500/10',
		icon: 'text-red-600 dark:text-red-400',
		label: 'Dikkat',
		path: 'M12 8v4m0 4h.01M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z',
	},
};

const c = config[type];
---

<aside class={`my-6 rounded-xl border border-l-4 p-4 ${c.wrap}`}>
	<div class="flex gap-3">
		<svg
			class={`mt-0.5 size-5 shrink-0 ${c.icon}`}
			viewBox="0 0 24 24"
			fill="none"
			stroke="currentColor"
			stroke-width="2"
			stroke-linecap="round"
			stroke-linejoin="round"
			aria-hidden="true"
		>
			<path d={c.path}></path>
		</svg>
		<div class="min-w-0 flex-1">
			<p class={`mb-1 font-semibold ${c.icon}`}>{title ?? c.label}</p>
			<div class="callout-body text-sm text-slate-700 dark:text-slate-300">
				<slot />
			</div>
		</div>
	</div>
</aside>

<style is:global>
	.callout-body > :first-child {
		margin-top: 0;
	}
	.callout-body > :last-child {
		margin-bottom: 0;
	}
	.callout-body p {
		margin: 0.4em 0;
	}
	.callout-body a {
		color: inherit;
		text-decoration: underline;
	}
</style>
