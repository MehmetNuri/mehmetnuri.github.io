---
// Sekmeli kod grubu: alt-çizgili sekmeler, EC çerçevesine bitişik.
// Kullanım (MDX):
//   <CodeGroup titles={['Astro','Next.js']}>
//   ```js title="astro.config.mjs"
//   ...
//   ```
//   ```js title="next.config.js"
//   ...
//   ```
//   </CodeGroup>
interface Props {
	titles: string[];
}
const { titles } = Astro.props;
---

<div class="code-group not-prose">
	<div class="cg-tabs" role="tablist">
		{
			titles.map((title, i) => (
				<button
					type="button"
					class="cg-tab"
					role="tab"
					aria-selected={i === 0 ? 'true' : 'false'}
				>
					{title}
				</button>
			))
		}
	</div>
	<div class="cg-panels"><slot /></div>
</div>

<style>
	.code-group {
		margin: 1.5rem 0;
	}
	.cg-tabs {
		display: flex;
		flex-wrap: wrap;
		gap: 0.15rem;
		border-bottom: 1px solid rgb(226 232 240);
		margin-bottom: 0.85rem;
	}
	.cg-tab {
		padding: 0.45rem 0.9rem;
		margin-bottom: -1px;
		font-size: 0.875rem;
		font-weight: 500;
		color: rgb(100 116 139);
		background: none;
		border: none;
		border-bottom: 2px solid transparent;
		cursor: pointer;
		transition:
			color 0.15s ease,
			border-color 0.15s ease;
	}
	.cg-tab:hover {
		color: rgb(15 23 42);
	}
	.cg-tab[aria-selected='true'] {
		color: var(--color-brand-600);
		border-bottom-color: var(--color-brand-600);
	}
	.cg-panels :global(.expressive-code) {
		margin: 0;
	}
	:global([data-theme='dark']) .cg-tabs {
		border-bottom-color: rgb(30 41 59);
	}
	:global([data-theme='dark']) .cg-tab {
		color: rgb(148 163 184);
	}
	:global([data-theme='dark']) .cg-tab:hover {
		color: rgb(241 245 249);
	}
	:global([data-theme='dark']) .cg-tab[aria-selected='true'] {
		color: var(--color-brand-400);
		border-bottom-color: var(--color-brand-400);
	}
</style>
