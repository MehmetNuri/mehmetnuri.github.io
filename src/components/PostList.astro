---
import type { Post } from '../lib/utils';
import { postSlug, readingMinutes } from '../lib/utils';
import { type Locale, localizePath, formatReadingTime } from '../i18n/ui';
import FormattedDate from './FormattedDate.astro';
import { Badge } from './starwind/badge';

interface Props {
	posts: Post[];
	lang: Locale;
}

const { posts, lang } = Astro.props;
---

<ul class="grid gap-5">
	{
		posts.map((post) => (
			<li data-post data-tags={(post.data.tags ?? []).join(' ')}>
				<a
					href={localizePath(lang, `/blog/${postSlug(post)}`)}
					class="group surface card-hover block h-full p-6"
				>
					<div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-xs">
						<time
							class="font-mono text-slate-500 dark:text-slate-400"
							datetime={post.data.pubDate.toISOString()}
						>
							<FormattedDate date={post.data.pubDate} lang={lang} />
						</time>
						<span class="text-slate-400">·</span>
						<span class="text-slate-500 dark:text-slate-400">
							{formatReadingTime(readingMinutes(post.body), lang)}
						</span>
						{post.data.category && (
							<Badge variant="primary" size="sm">
								{post.data.category}
							</Badge>
						)}
					</div>
					<h2 class="mt-2 text-xl font-semibold text-slate-900 transition group-hover:text-brand-600 dark:text-white dark:group-hover:text-brand-400">
						{post.data.title}
					</h2>
					{post.data.description && (
						<p class="mt-1.5 text-sm text-slate-600 dark:text-slate-400">{post.data.description}</p>
					)}
					{post.data.tags && post.data.tags.length > 0 && (
						<div class="mt-3 flex flex-wrap gap-2">
							{post.data.tags.map((tag) => (
								<span class="text-xs text-slate-500 dark:text-slate-400">#{tag}</span>
							))}
						</div>
					)}
				</a>
			</li>
		))
	}
</ul>
