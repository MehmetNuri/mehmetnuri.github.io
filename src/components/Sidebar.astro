---
import { getPostsByLocale, getCategories, getTags, postSlug, slugify } from '../lib/utils';
import { type Locale, localizePath, useTranslations } from '../i18n/ui';

interface Props {
	lang: Locale;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const posts = await getPostsByLocale(lang);
const categories = getCategories(posts);
const tags = getTags(posts);
const recent = posts.slice(0, 5);

const card = 'surface p-5';
const heading = 'mb-3 text-sm font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400';
---

<aside class="order-last space-y-6 lg:order-first lg:sticky lg:top-20 lg:self-start">
	<div class={card}>
		<div class="flex items-center gap-3">
			<span
				class="grid size-11 place-items-center rounded-xl bg-gradient-to-br from-brand-500 to-cyan-400 text-sm font-extrabold text-white"
				>MN</span
			>
			<div>
				<p class="font-semibold text-slate-900 dark:text-white">Mehmet Nuri</p>
				<p class="text-xs text-slate-500 dark:text-slate-400">{t('site.tagline')}</p>
			</div>
		</div>
		<p class="mt-3 text-sm text-slate-600 dark:text-slate-400">{t('site.bio')}</p>
	</div>

	{
		categories.length > 0 && (
			<div class={card}>
				<h3 class={heading}>{t('sidebar.categories')}</h3>
				<ul class="space-y-1">
					{categories.map((c) => (
						<li>
							<a
								href={localizePath(lang, `/kategori/${slugify(c.name)}`)}
								class="flex items-center justify-between rounded-lg px-2 py-1.5 text-sm text-slate-700 transition hover:bg-slate-100 hover:text-brand-600 dark:text-slate-300 dark:hover:bg-slate-800 dark:hover:text-brand-400"
							>
								<span>{c.name}</span>
								<span class="text-xs text-slate-400">{c.count}</span>
							</a>
						</li>
					))}
				</ul>
			</div>
		)
	}

	{
		tags.length > 0 && (
			<div class={card}>
				<h3 class={heading}>{t('sidebar.tags')}</h3>
				<div class="flex flex-wrap gap-2">
					{tags.map((tag) => (
						<a
							href={localizePath(lang, `/etiket/${slugify(tag.name)}`)}
							class="rounded-full border border-slate-200 bg-slate-50 px-2.5 py-1 text-xs font-medium text-slate-600 transition hover:border-brand-500 hover:text-brand-600 dark:border-slate-800 dark:bg-slate-800/60 dark:text-slate-400 dark:hover:text-brand-400"
						>
							#{tag.name}
						</a>
					))}
				</div>
			</div>
		)
	}

	{
		recent.length > 0 && (
			<div class={card}>
				<h3 class={heading}>{t('sidebar.recent')}</h3>
				<ul class="space-y-3">
					{recent.map((post) => (
						<li>
							<a
								href={localizePath(lang, `/blog/${postSlug(post)}`)}
								class="text-sm font-medium text-slate-700 transition hover:text-brand-600 dark:text-slate-300 dark:hover:text-brand-400"
							>
								{post.data.title}
							</a>
						</li>
					))}
				</ul>
			</div>
		)
	}
</aside>
